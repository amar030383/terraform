# Copy this file to terraform.tfvars and fill in your values
# cp terraform.tfvars.example terraform.tfvars

# REQUIRED: Path to your SSH public key
ssh_public_key_path = "~/.ssh/id_rsa.pub"

# Optional overrides
resource_group_name = "license-server-app-rg"
location            = "australiaeast"       # or eastus, eastus2, westus2
vm_name             = "license-server-vm"
vm_size             = "Standard_B2ats_v2"  # 2 vCPU, 1 GiB - Australia East
admin_username      = "azureuser"
os_disk_size_gb     = 30
